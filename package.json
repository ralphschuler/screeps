{
  "name": "screeps-ant-swarm",
  "version": "1.0.0",
  "description": "Advanced Screeps AI using swarm intelligence and distributed colony management",
  "main": "packages/screeps-bot/dist/main.js",
  "screeps_bot": true,
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "packages/@ralphschuler/*"
  ],
  "engines": {
    "node": ">=24 <25",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "postinstall": "git submodule update --init --recursive || echo 'Note: Git submodules not initialized. This is normal in CI environments.'",
    "check-versions": "node scripts/check-versions.js",
    "sync:deps": "node scripts/sync-framework-deps.js",
    "sync:deps:check": "node scripts/sync-framework-deps.js --check",
    "quality:duplication": "jscpd . --config .jscpd.json",
    "quality:complexity": "node scripts/analyze-complexity.cjs",
    "quality:baseline": "npm run quality:duplication && npm run quality:complexity",
    "profile:live:cpu": "node scripts/live-cpu-profile.mjs --samples 20 --interval 3000 --shards shard0,shard1,shard2,shard3 --out-dir artifacts/cpu-profile",
    "check:alliance-safety": "node scripts/check-alliance-safety.js",
    "verify": "npm run build && npm run typecheck && npm run lint:all && npm run test:all && npm run check:alliance-safety && npm audit --omit=dev --audit-level=high",
    "deploy:preflight": "npm run sync:deps:check && npm run check:alliance-safety && npm run build",
    "build": "npm run build:framework && npm run build:bot",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "build:bot": "npm run build -w screeps-typescript-starter",
    "build:framework": "npm run build:core && npm run build:stats && npm run build:kernel && npm run build:utils && npm run build:cache && npm run build:console && npm run build:layouts && npm run build:pathfinding && npm run build:remote-mining && npm run build:visuals && npm run build:chemistry && npm run build:standards && npm run build:memory && npm run build:economy && npm run build:intershard && npm run build:defense && npm run build:empire && npm run build:pheromones && npm run build:spawn && npm run build:clusters && npm run build:roles",
    "build:mod": "npm run build -w screepsmod-testing",
    "build:posis": "npm run build -w @ralphschuler/screeps-posis",
    "build:core": "npm run build -w @ralphschuler/screeps-core",
    "build:cache": "npm run build -w @ralphschuler/screeps-cache",
    "build:clusters": "npm run build -w @ralphschuler/screeps-clusters",
    "build:kernel": "npm run build -w @ralphschuler/screeps-kernel",
    "build:stats": "npm run build -w @ralphschuler/screeps-stats",
    "build:console": "npm run build -w @ralphschuler/screeps-console",
    "build:empire": "npm run build -w @ralphschuler/screeps-empire",
    "build:layouts": "npm run build -w @ralphschuler/screeps-layouts",
    "build:memory": "npm run build -w @ralphschuler/screeps-memory",
    "build:intershard": "npm run build -w @ralphschuler/screeps-intershard",
    "build:visuals": "npm run build -w @ralphschuler/screeps-visuals",
    "build:roles": "npm run build -w @ralphschuler/screeps-roles",
    "build:chemistry": "npm run build -w @ralphschuler/screeps-chemistry",
    "build:standards": "npm run build -w @ralphschuler/screeps-standards",
    "build:defense": "npm run build -w @ralphschuler/screeps-defense",
    "build:economy": "npm run build -w @ralphschuler/screeps-economy",
    "build:spawn": "npm run build -w @ralphschuler/screeps-spawn",
    "build:utils": "npm run build -w @ralphschuler/screeps-utils",
    "build:pathfinding": "npm run build -w @ralphschuler/screeps-pathfinding",
    "build:remote-mining": "npm run build -w @ralphschuler/screeps-remote-mining",
    "build:pheromones": "npm run build -w @ralphschuler/screeps-pheromones",
    "build:tools": "npm run build:posis && npm run build:mod",
    "build:all": "npm run build && npm run build:tools",
    "pretest": "npm run build:framework",
    "test": "npm test -w screeps-typescript-starter",
    "test:unit": "npm run test:unit -w screeps-typescript-starter",
    "test:integration": "npm run test:integration -w screeps-typescript-starter",
    "test:server": "npm run test:server:smoke",
    "server:ci:up": "npm run server:ci:up -w @ralphschuler/screeps-server",
    "server:ci:down": "npm run server:ci:down -w @ralphschuler/screeps-server",
    "server:local:up": "npm run server:local:up -w @ralphschuler/screeps-server",
    "server:local:down": "npm run server:local:down -w @ralphschuler/screeps-server",
    "server:local:reset": "npm run server:local:reset -w @ralphschuler/screeps-server",
    "server:local:logs": "npm run server:local:logs -w @ralphschuler/screeps-server",
    "test:server:smoke": "npm run test:smoke -w @ralphschuler/screeps-server",
    "test:server:long": "npm run test:long -w @ralphschuler/screeps-server",
    "test:server:packages": "npm run test:packages -w @ralphschuler/screeps-server",
    "test:perf:baseline": "npm run test:perf:baseline -w screeps-typescript-starter",
    "test:perf:compare": "npm run test:perf:compare -w screeps-typescript-starter",
    "test:posis": "npm test -w @ralphschuler/screeps-posis",
    "test:core": "npm test -w @ralphschuler/screeps-core",
    "test:cache": "npm test -w @ralphschuler/screeps-cache",
    "test:clusters": "npm test -w @ralphschuler/screeps-clusters",
    "test:kernel": "npm test -w @ralphschuler/screeps-kernel",
    "test:stats": "npm test -w @ralphschuler/screeps-stats",
    "test:console": "npm test -w @ralphschuler/screeps-console",
    "test:empire": "npm test -w @ralphschuler/screeps-empire",
    "test:layouts": "npm test -w @ralphschuler/screeps-layouts",
    "test:intershard": "npm test -w @ralphschuler/screeps-intershard",
    "test:visuals": "npm test -w @ralphschuler/screeps-visuals",
    "test:roles": "npm test -w @ralphschuler/screeps-roles",
    "test:chemistry": "npm test -w @ralphschuler/screeps-chemistry",
    "test:standards": "npm test -w @ralphschuler/screeps-standards",
    "test:defense": "npm test -w @ralphschuler/screeps-defense",
    "test:spawn": "npm test -w @ralphschuler/screeps-spawn",
    "test:utils": "npm test -w @ralphschuler/screeps-utils",
    "test:pathfinding": "npm test -w @ralphschuler/screeps-pathfinding",
    "test:remote-mining": "npm test -w @ralphschuler/screeps-remote-mining",
    "test:pheromones": "npm test -w @ralphschuler/screeps-pheromones",
    "test:economy": "npm test -w @ralphschuler/screeps-economy",
    "test:all": "npm run test:scripts && npm test --workspaces --if-present",
    "test:scripts": "node --test scripts/test/*.test.mjs",
    "lint": "npm run lint -w screeps-typescript-starter -- --max-warnings=0",
    "lint:kernel": "npm run lint -w @ralphschuler/screeps-kernel",
    "lint:roles": "npm run lint -w @ralphschuler/screeps-roles",
    "lint:pathfinding": "npm run lint -w @ralphschuler/screeps-pathfinding",
    "lint:remote-mining": "npm run lint -w @ralphschuler/screeps-remote-mining",
    "lint:pheromones": "npm run lint -w @ralphschuler/screeps-pheromones",
    "lint:spawn": "npm run lint -w @ralphschuler/screeps-spawn",
    "lint:economy": "npm run lint -w @ralphschuler/screeps-economy",
    "lint:defense": "npm run lint -w @ralphschuler/screeps-defense",
    "lint:chemistry": "npm run lint -w @ralphschuler/screeps-chemistry",
    "lint:utils": "npm run lint -w @ralphschuler/screeps-utils",
    "lint:posis": "npm run lint -w @ralphschuler/screeps-posis",
    "lint:all": "npm run lint --workspaces --if-present -- --max-warnings=0",
    "deploy": "npm run push",
    "push": "DEPLOY=true npm run push -w screeps-typescript-starter",
    "watch": "npm run watch -w screeps-typescript-starter",
    "respawn": "node utils/respawner.js",
    "build:docs": "node scripts/build-docs.js",
    "docs": "typedoc",
    "docs:serve": "npx http-server docs/api -p 8080 -o"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ralphschuler/screeps.git"
  },
  "keywords": [
    "screeps",
    "ai",
    "bot",
    "swarm",
    "typescript",
    "game"
  ],
  "author": "",
  "license": "Unlicense",
  "bugs": {
    "url": "https://github.com/ralphschuler/screeps/issues"
  },
  "homepage": "https://github.com/ralphschuler/screeps#readme",
  "overrides": {
    "@eslint/eslintrc": {
      "ajv": "^6.12.6"
    },
    "@hono/node-server": "^1.19.13",
    "eslint": {
      "ajv": "^6.12.6"
    },
    "axios": "^1.15.2",
    "brace-expansion": "^1.1.13",
    "follow-redirects": "^1.16.0",
    "path-to-regexp": "^8.4.2",
    "qs": "^6.15.1",
    "serve-handler": {
      "minimatch": "3.1.5"
    },
    "undici": "^8.1.0"
  },
  "devDependencies": {
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.10",
    "@types/node": "^24.13.2",
    "@types/screeps": "^3.4.0",
    "@types/sinon": "^22.0.0",
    "ajv": "^8.20.0",
    "chai": "^6.2.2",
    "jscpd": "^5.0.11",
    "mocha": "^11.7.6",
    "screeps-api": "^2.0.1",
    "sinon": "^22.0.0",
    "ts-node": "^10.9.2",
    "ts-prune": "^0.10.3",
    "tsx": "^4.22.4",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.12.0",
    "typescript": "^5.4.3"
  }
}
