{
  "name": "screeps-typescript-starter",
  "version": "3.0.0",
  "description": "",
  "main": "main.js",
  "scripts": {
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "bundle:check": "node scripts/check-bundle-size.js",
    "build": "rollup -c && npm run bundle:check",
    "typecheck": "npm run build",
    "push": "DEPLOY=true rollup -c && npm run bundle:check",
    "test": "npm run test:unit",
    "test:unit": "mocha test/unit/**/*.ts",
    "test:coverage": "c8 --reporter=text --reporter=html --reporter=lcov npm run test:unit",
    "test:coverage:report": "c8 report --reporter=html",
    "test:integration": "npm run build && npm --workspace @ralphschuler/screeps-server run test:smoke",
    "test:performance": "npm --workspace @ralphschuler/screeps-server run test:long",
    "test:perf:baseline": "npm run test:performance && node scripts/update-baseline.js",
    "test:perf:compare": "npm run test:performance && node scripts/analyze-performance.js",
    "watch": "rollup -cw --environment DEST:screeps"
  },
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/screepers/screeps-typescript-starter.git"
  },
  "author": "",
  "license": "Unlicense",
  "bugs": {
    "url": "https://github.com/screepers/screeps-typescript-starter/issues"
  },
  "homepage": "https://github.com/screepers/screeps-typescript-starter#readme",
  "devDependencies": {
    "@rollup/plugin-alias": "^6.0.0",
    "@rollup/plugin-commonjs": "^29.0.3",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/chai": "^5.2.3",
    "@types/lz-string": "^1.5.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^24.13.2",
    "@types/screeps": "^3.4.0",
    "@types/sinon": "^21.0.1",
    "@types/sinon-chai": "^4.0.0",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.51.0",
    "c8": "^11.0.0",
    "chai": "^6.2.2",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import": "^2.24.0",
    "minimist": "^1.2.8",
    "mocha": "^11.7.6",
    "prettier": "^3.9.3",
    "rollup": "^4.62.2",
    "rollup-plugin-clear": "^2.0.7",
    "rollup-plugin-screeps": "^1.0.1",
    "rollup-plugin-typescript2": "^0.37.0",
    "screeps-api": "^2.0.1",
    "sinon": "^22.0.0",
    "sinon-chai": "^4.0.1",
    "ts-node": "^10.2.0",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.22.4",
    "typescript": "^5.4.3"
  },
  "dependencies": {
    "@ralphschuler/screeps-cache": "*",
    "@ralphschuler/screeps-chemistry": "*",
    "@ralphschuler/screeps-clusters": "*",
    "@ralphschuler/screeps-console": "*",
    "@ralphschuler/screeps-core": "*",
    "@ralphschuler/screeps-defense": "*",
    "@ralphschuler/screeps-economy": "*",
    "@ralphschuler/screeps-empire": "*",
    "@ralphschuler/screeps-intershard": "*",
    "@ralphschuler/screeps-kernel": "*",
    "@ralphschuler/screeps-layouts": "*",
    "@ralphschuler/screeps-memory": "*",
    "@ralphschuler/screeps-pathfinding": "*",
    "@ralphschuler/screeps-pheromones": "*",
    "@ralphschuler/screeps-remote-mining": "*",
    "@ralphschuler/screeps-roles": "*",
    "@ralphschuler/screeps-spawn": "*",
    "@ralphschuler/screeps-standards": "*",
    "@ralphschuler/screeps-stats": "*",
    "@ralphschuler/screeps-utils": "*",
    "@ralphschuler/screeps-visuals": "*",
    "lz-string": "^1.5.0",
    "screeps-cartographer": "^1.8.15",
    "source-map": "~0.7.6"
  },
  "overrides": {
    "axios": "^1.7.0",
    "shelljs": "^0.8.5"
  },
  "ts-node": {
    "esm": true,
    "experimentalSpecifierResolution": "node",
    "transpileOnly": true,
    "compilerOptions": {
      "module": "esnext",
      "moduleResolution": "node"
    }
  }
}
