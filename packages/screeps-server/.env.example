STEAM_KEY=<your steam api key>
TUNNEL_TOKEN=<your cloudflare tunnel token>
MAPTOOL_PASS=<your super secret password>


# Screeps Exporter Configuration
EXPORTER_MODE=memory
EXPORTER_POLL_INTERVAL_MS=15000
EXPORTER_MEMORY_PATH=stats
EXPORTER_SHARD=shard0

# Bot credentials for the exporter
# Use either SCREEPS_TOKEN or SCREEPS_BOT_USERNAME + SCREEPS_BOT_PASSWORD
SCREEPS_TOKEN=
SCREEPS_BOT_USERNAME=
SCREEPS_BOT_PASSWORD=
