  "keywords": [
    "screeps",
    "standards",
    "protocols",
    "typescript"
  ],
  "author": "Ralph Schuler",
  "license": "Unlicense",
  "dependencies": {
    "@ralphschuler/screeps-core": "*"
  },
  "devDependencies": {
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.9.1",
    "@types/screeps": "^3.4.0",
    "chai": "^6.2.2",
    "mocha": "^11.7.6",
    "ts-node": "^10.2.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.4.3"
  }
}
