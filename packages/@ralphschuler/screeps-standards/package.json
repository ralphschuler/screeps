{
  "name": "@ralphschuler/screeps-standards",
  "version": "0.1.0",
  "description": "Screeps SS2 terminal communication standard",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "private": false,
  "scripts": {
    "build": "tsc",
    "test": "npm run build -w @ralphschuler/screeps-core && npm run build && node --test test/*.test.mjs",
    "prepublishOnly": "npm run build",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "prebuild": "npm run build -w @ralphschuler/screeps-core --if-present"
