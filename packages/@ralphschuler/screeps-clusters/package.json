{
  "name": "@ralphschuler/screeps-clusters",
  "version": "0.1.0",
  "description": "Colony cluster management and inter-room coordination",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "private": false,
  "scripts": {
    "build": "tsc",
    "test": "mocha test/**/*.test.ts",
    "prepublishOnly": "npm run build",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "prebuild": "npm run build -w @ralphschuler/screeps-core -w @ralphschuler/screeps-defense -w @ralphschuler/screeps-kernel -w @ralphschuler/screeps-stats --if-present"
  },
  "keywords": [
    "screeps",
    "clusters",
    "coordination",
    "typescript"
  ],
  "author": "Ralph Schuler",
  "license": "Unlicense",
  "devDependencies": {
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.9.1",
    "@types/screeps": "^3.4.0",
    "chai": "^6.2.2",
    "mocha": "^11.7.6",
    "ts-node": "^10.2.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.4.3"
  },
  "dependencies": {
    "@ralphschuler/screeps-core": "*",
    "@ralphschuler/screeps-defense": "*",
    "@ralphschuler/screeps-kernel": "*",
    "@ralphschuler/screeps-stats": "*"
  }
}
