{
  "name": "@ralphschuler/screeps-spawn",
  "version": "0.1.0",
  "description": "Spawn system for ralphschuler/screeps bot - body optimization, queue management, and role prioritization",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "private": true,
  "scripts": {
    "prebuild": "npm run build -w @ralphschuler/screeps-cache -w @ralphschuler/screeps-core -w @ralphschuler/screeps-defense -w @ralphschuler/screeps-economy -w @ralphschuler/screeps-empire -w @ralphschuler/screeps-intershard -w @ralphschuler/screeps-memory -w @ralphschuler/screeps-utils --if-present",
    "build": "tsc",
    "test": "mocha test/**/*.test.ts",
    "prepublishOnly": "npm run build",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix"
  },
  "keywords": [
    "screeps",
    "spawn",
    "creep",
    "body-optimization",
    "queue-management",
    "typescript"
  ],
  "author": "Ralph Schuler",
  "license": "Unlicense",
  "repository": {
    "type": "git",
    "url": "https://github.com/ralphschuler/screeps.git",
    "directory": "packages/screeps-spawn"
  },
  "bugs": {
    "url": "https://github.com/ralphschuler/screeps/issues"
  },
  "homepage": "https://github.com/ralphschuler/screeps/tree/main/packages/screeps-spawn#readme",
  "dependencies": {
    "@ralphschuler/screeps-cache": "*",
    "@ralphschuler/screeps-core": "*",
    "@ralphschuler/screeps-defense": "*",
    "@ralphschuler/screeps-economy": "*",
    "@ralphschuler/screeps-empire": "*",
    "@ralphschuler/screeps-intershard": "*",
    "@ralphschuler/screeps-memory": "*",
    "@ralphschuler/screeps-utils": "*"
  },
  "devDependencies": {
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.10",
    "@types/node": "^26.1.0",
    "@types/screeps": "^3.4.0",
    "chai": "^6.2.2",
    "mocha": "^11.7.6",
    "ts-node": "^10.2.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.4.3"
  }
}
